---
import Layout from '../layout.astro'
import { createSystemClient } from '../../system/client.js'
import type { CommentStatus } from '../../system/types.js'

const config = (await import('virtual:astro-cms/config')).default
const env = (Astro.locals as { runtime?: { env: Record<string, unknown> } }).runtime?.env ?? {}
const db = env['DB'] as D1Database
const system = createSystemClient(db)

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string
  const id = parseInt(form.get('id') as string, 10)

  if (action === 'approve') await system.comments.updateStatus(id, 'approved')
  if (action === 'reject')  await system.comments.updateStatus(id, 'rejected')
  if (action === 'pending') await system.comments.updateStatus(id, 'pending')
  if (action === 'delete')  await system.comments.delete(id)

  return Astro.redirect('/admin/system/comments')
}

const statusFilter = Astro.url.searchParams.get('status') as CommentStatus | null
const comments = await system.comments.list(statusFilter ? { status: statusFilter } : {})

const statusLabels: Record<CommentStatus, string> = {
  pending:  'En attente',
  approved: 'Approuvé',
  rejected: 'Rejeté',
}

const statusColors: Record<CommentStatus, string> = {
  pending:  'background:#fef3c7; color:#92400e',
  approved: 'background:#d1fae5; color:#065f46',
  rejected: 'background:#fee2e2; color:#991b1b',
}

const counts = {
  pending:  comments.filter(c => c.status === 'pending').length,
  approved: comments.filter(c => c.status === 'approved').length,
  rejected: comments.filter(c => c.status === 'rejected').length,
}
---

<Layout config={config} title="Commentaires" activeSystem="comments">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px">
    <h1 style="font-size:22px; font-weight:600">Commentaires</h1>
    <span style="font-size:13px; color:#9ca3af">{comments.length} commentaire{comments.length !== 1 ? 's' : ''}</span>
  </div>

  <!-- Status filters -->
  <div style="display:flex; gap:8px; margin-bottom:20px">
    <a href="/admin/system/comments"
      style={`padding:6px 14px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none;
        ${!statusFilter ? 'background:#111827; color:#fff' : 'background:#f3f4f6; color:#374151'}`}>
      Tous ({comments.length})
    </a>
    {(['pending', 'approved', 'rejected'] as CommentStatus[]).map(s => (
      <a href={`/admin/system/comments?status=${s}`}
        style={`padding:6px 14px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none;
          ${statusFilter === s ? 'background:#111827; color:#fff' : 'background:#f3f4f6; color:#374151'}`}>
        {statusLabels[s]} ({counts[s]})
      </a>
    ))}
  </div>

  <!-- Comments list -->
  {comments.length === 0 ? (
    <div style="text-align:center; padding:60px; color:#9ca3af">
      <p style="font-size:16px">Aucun commentaire{statusFilter ? ` avec le statut "${statusLabels[statusFilter]}"` : ''}.</p>
    </div>
  ) : (
    <div style="display:flex; flex-direction:column; gap:12px">
      {comments.map((c) => (
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:16px 20px">
          <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px">
            <div>
              <div style="display:flex; align-items:center; gap:10px">
                <span style="font-size:14px; font-weight:600">{c.author}</span>
                <span style="font-size:12px; color:#9ca3af">{c.email}</span>
                <span style={`font-size:11px; font-weight:500; padding:2px 8px; border-radius:4px; ${statusColors[c.status]}`}>
                  {statusLabels[c.status]}
                </span>
              </div>
              <div style="font-size:12px; color:#9ca3af; margin-top:2px">
                {c.collection} #{c.entryId} · {new Date(c.createdAt).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}
              </div>
            </div>
            <div style="display:flex; gap:8px; flex-shrink:0">
              {c.status !== 'approved' && (
                <form method="POST" style="display:inline">
                  <input type="hidden" name="_action" value="approve" />
                  <input type="hidden" name="id" value={String(c.id)} />
                  <button type="submit"
                    style="padding:5px 12px; background:#d1fae5; color:#065f46; border:none; border-radius:5px; font-size:12px; font-weight:500; cursor:pointer">
                    Approuver
                  </button>
                </form>
              )}
              {c.status !== 'rejected' && (
                <form method="POST" style="display:inline">
                  <input type="hidden" name="_action" value="reject" />
                  <input type="hidden" name="id" value={String(c.id)} />
                  <button type="submit"
                    style="padding:5px 12px; background:#fee2e2; color:#991b1b; border:none; border-radius:5px; font-size:12px; font-weight:500; cursor:pointer">
                    Rejeter
                  </button>
                </form>
              )}
              {c.status !== 'pending' && (
                <form method="POST" style="display:inline">
                  <input type="hidden" name="_action" value="pending" />
                  <input type="hidden" name="id" value={String(c.id)} />
                  <button type="submit"
                    style="padding:5px 12px; background:#f3f4f6; color:#374151; border:none; border-radius:5px; font-size:12px; cursor:pointer">
                    En attente
                  </button>
                </form>
              )}
              <form method="POST" style="display:inline" onsubmit="return confirm('Supprimer ce commentaire ?')">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={String(c.id)} />
                <button type="submit"
                  style="padding:5px 12px; background:none; border:1px solid #fecaca; color:#ef4444; border-radius:5px; font-size:12px; cursor:pointer">
                  Supprimer
                </button>
              </form>
            </div>
          </div>
          <p style="font-size:14px; color:#374151; line-height:1.5; white-space:pre-wrap">{c.content}</p>
        </div>
      ))}
    </div>
  )}
</Layout>
