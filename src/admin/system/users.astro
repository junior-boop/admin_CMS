---
import Layout from '../layout.astro'
const config = (await import('virtual:astro-cms/config')).default
---

<Layout config={config} title="Users" activeSystem="users">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px">
    <h1 style="font-size:22px; font-weight:600">Utilisateurs</h1>
  </div>

  <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:40px; text-align:center; color:#6b7280">
    <div style="font-size:32px; margin-bottom:12px">👤</div>
    <p style="font-size:16px; font-weight:500; color:#374151; margin-bottom:8px">Gestion des utilisateurs</p>
    <p style="font-size:14px; line-height:1.6; max-width:480px; margin:0 auto; color:#6b7280">
      La gestion multi-utilisateurs sera disponible dans une prochaine version.
      Pour l'instant, l'accès admin est contrôlé via la variable d'environnement
      <code style="background:#f3f4f6; padding:2px 6px; border-radius:4px">ADMIN_PASSWORD</code>.
    </p>

    <div style="margin-top:28px; background:#fef3c7; border:1px solid #fde68a; border-radius:8px; padding:16px 20px; text-align:left; max-width:420px; margin-left:auto; margin-right:auto">
      <p style="font-size:13px; color:#92400e; line-height:1.6">
        Définissez <strong>ADMIN_PASSWORD</strong> dans vos variables d'environnement Cloudflare (wrangler.toml ou le dashboard) pour sécuriser l'accès.
      </p>
    </div>
  </div>
</Layout>
