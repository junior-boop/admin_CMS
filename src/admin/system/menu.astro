---
import Layout from '../layout.astro'
import { createSystemClient } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const system = createSystemClient(db)

function toSlug(name: string) {
  return name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'create') {
    const name = (form.get('name') as string).trim()
    if (name) await system.menu.create({ name, slug: toSlug(name) })
  }

  if (action === 'delete') {
    const id = parseInt(form.get('id') as string, 10)
    await system.menu.delete(id)
  }

  return Astro.redirect('/admin/system/menu')
}

const menus = await system.menu.list()
---

<Layout config={config} title="Menus" activeSystem="menu">
  <div class="page-header">
    <h1>Menus</h1>
    <span class="badge">{menus.length} menu{menus.length !== 1 ? 's' : ''}</span>
  </div>

  <div class="create-card">
    <p class="card-title">Nouveau menu</p>
    <form method="POST" class="create-form">
      <input type="hidden" name="_action" value="create" />
      <div class="input-group">
        <label>Nom</label>
        <input type="text" name="name" required placeholder="ex: Navigation principale" class="form-input" />
      </div>
      <button type="submit" class="btn btn-primary">
        + Créer
      </button>
    </form>
  </div>

  {menus.length === 0 ? (
    <div class="empty-state">
      <p>Aucun menu pour l'instant.</p>
    </div>
  ) : (
    <div class="menu-list">
      {menus.map((menu) => (
        <div class="menu-card">
          <div class="menu-info">
            <p class="menu-name">{menu.name}</p>
            <span class="menu-slug">/{menu.slug}</span>
          </div>
          <div class="menu-actions">
            <a href={`/admin/system/menu/${menu.id}`} class="btn btn-secondary">
              Gérer les items
            </a>
            <form method="POST" onsubmit="return confirm('Supprimer ce menu et tous ses items ?')">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={String(menu.id)} />
              <button type="submit" class="btn btn-danger">Supprimer</button>
            </form>
          </div>
        </div>
      ))}
    </div>
  )}
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }
  .page-header h1 {
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
  }
  .badge {
    font-size: 13px;
    color: var(--text-light);
    background: var(--surface-elevated);
    padding: 6px 12px;
    border-radius: 20px;
  }
  .create-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: var(--shadow);
  }
  .card-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 16px;
  }
  .create-form {
    display: flex;
    gap: 12px;
    align-items: flex-end;
  }
  .input-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .input-group label {
    font-size: 12px;
    color: var(--text-light);
  }
  .form-input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 14px;
    transition: all 0.2s;
  }
  .form-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgb(99 102 241 / 0.15);
  }
  .menu-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .menu-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow);
    transition: all 0.2s;
  }
  .menu-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgb(99 102 241 / 0.1);
  }
  .menu-info { display: flex; align-items: center; gap: 12px; }
  .menu-name {
    font-size: 16px;
    font-weight: 500;
    color: var(--text);
  }
  .menu-slug {
    font-size: 13px;
    color: var(--text-light);
    font-family: monospace;
    background: var(--surface-elevated);
    padding: 4px 8px;
    border-radius: 6px;
  }
  .menu-actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .empty-state {
    text-align: center;
    padding: 60px;
    color: var(--text-light);
    background: var(--surface);
    border-radius: 16px;
  }

  @media (max-width: 640px) {
    .create-form { flex-direction: column; }
    .menu-card { flex-direction: column; gap: 16px; align-items: flex-start; }
    .menu-actions { width: 100%; justify-content: space-between; }
  }
</style>
