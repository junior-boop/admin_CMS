---
import Layout from '../layout.astro'
import { createSystemClient } from '../../system/client.js'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const system = createSystemClient(db)

function toSlug(name: string) {
  return name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'create') {
    const name = (form.get('name') as string).trim()
    if (name) await system.menu.create({ name, slug: toSlug(name) })
  }

  if (action === 'delete') {
    const id = parseInt(form.get('id') as string, 10)
    await system.menu.delete(id)
  }

  return Astro.redirect('/admin/system/menu')
}

const menus = await system.menu.list()
---

<Layout config={config} title="Menus" activeSystem="menu">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px">
    <h1 style="font-size:22px; font-weight:600">Menus</h1>
    <span style="font-size:13px; color:#9ca3af">{menus.length} menu{menus.length !== 1 ? 's' : ''}</span>
  </div>

  <!-- Create form -->
  <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:20px; margin-bottom:24px">
    <p style="font-size:13px; font-weight:500; color:#374151; margin-bottom:12px">Nouveau menu</p>
    <form method="POST" style="display:flex; gap:10px; align-items:flex-end">
      <input type="hidden" name="_action" value="create" />
      <div style="flex:1">
        <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Nom</label>
        <input type="text" name="name" required placeholder="ex: Navigation principale"
          style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
      </div>
      <button type="submit"
        style="padding:8px 16px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:500; cursor:pointer; white-space:nowrap">
        + Créer
      </button>
    </form>
  </div>

  <!-- Menus list -->
  {menus.length === 0 ? (
    <div style="text-align:center; padding:60px; color:#9ca3af">
      <p style="font-size:16px">Aucun menu pour l'instant.</p>
    </div>
  ) : (
    <div style="display:flex; flex-direction:column; gap:12px">
      {menus.map((menu) => (
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:16px 20px; display:flex; align-items:center; justify-content:space-between">
          <div>
            <p style="font-size:15px; font-weight:500">{menu.name}</p>
            <p style="font-size:12px; color:#9ca3af; margin-top:2px; font-family:monospace">{menu.slug}</p>
          </div>
          <div style="display:flex; gap:16px; align-items:center">
            <a href={`/admin/system/menu/${menu.id}`}
              style="font-size:13px; color:#2563eb; text-decoration:none; font-weight:500">
              Gérer les items →
            </a>
            <form method="POST" style="display:inline" onsubmit="return confirm('Supprimer ce menu et tous ses items ?')">
              <input type="hidden" name="_action" value="delete" />
              <input type="hidden" name="id" value={String(menu.id)} />
              <button type="submit"
                style="background:none; border:none; color:#ef4444; font-size:13px; cursor:pointer">
                Supprimer
              </button>
            </form>
          </div>
        </div>
      ))}
    </div>
  )}
</Layout>
