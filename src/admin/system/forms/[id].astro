---
import Layout from '../../layout.astro'
import { createSystemClient } from '@geniusofdigital/astro-cms/system'
import type { FormFieldType } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const system = createSystemClient(db)

const { id } = Astro.params as { id: string }
const formId = parseInt(id, 10)

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'addField') {
    const label = (form.get('label') as string).trim()
    const type = (form.get('type') as FormFieldType)
    const required = form.get('required') === 'on'
    const placeholder = (form.get('placeholder') as string | null)?.trim() || undefined
    const optionsRaw = (form.get('options') as string | null)?.trim()
    const options = optionsRaw ? optionsRaw.split('\n').map(s => s.trim()).filter(Boolean) : undefined
    const order = parseInt(form.get('order') as string || '0', 10)
    if (label && type) {
      await system.forms.addField(formId, { label, type, required, placeholder, options, order })
    }
  }

  if (action === 'deleteField') {
    const fieldId = parseInt(form.get('field_id') as string, 10)
    await system.forms.deleteField(fieldId)
  }

  return Astro.redirect(`/admin/system/forms/${id}`)
}

const formData = await system.forms.get(formId)
if (!formData) return new Response('Formulaire introuvable', { status: 404 })

const fields = await system.forms.listFields(formId)

const FIELD_TYPES: FormFieldType[] = ['text', 'email', 'textarea', 'select', 'radio', 'checkbox', 'number', 'date', 'tel', 'url']

const typeLabels: Record<FormFieldType, string> = {
  text:     'Texte court',
  email:    'Email',
  textarea: 'Texte long',
  select:   'Liste déroulante',
  radio:    'Choix unique',
  checkbox: 'Cases à cocher',
  number:   'Nombre',
  date:     'Date',
  tel:      'Téléphone',
  url:      'URL',
}
---

<Layout config={config} title={`Formulaire : ${formData.name}`} activeSystem="forms">
  <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px">
    <a href="/admin/system/forms" style="color:#6b7280; font-size:13px; text-decoration:none">← Formulaires</a>
    <h1 style="font-size:20px; font-weight:600">{formData.name}</h1>
    <span style="font-size:12px; color:#9ca3af; font-family:monospace">/{formData.slug}</span>
  </div>

  {formData.description && (
    <p style="font-size:14px; color:#6b7280; margin-bottom:20px">{formData.description}</p>
  )}

  <!-- Add field form -->
  <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:20px; margin-bottom:24px">
    <p style="font-size:13px; font-weight:500; color:#374151; margin-bottom:14px">Ajouter une question</p>
    <form method="POST">
      <input type="hidden" name="_action" value="addField" />

      <div style="display:grid; grid-template-columns:2fr 1fr 1fr; gap:12px; margin-bottom:12px">
        <div>
          <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Label / Question *</label>
          <input type="text" name="label" required placeholder="ex: Votre nom"
            style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
        </div>

        <div>
          <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Type *</label>
          <select name="type" required id="field-type"
            style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; background:#fff">
            {FIELD_TYPES.map(t => <option value={t}>{typeLabels[t]}</option>)}
          </select>
        </div>

        <div>
          <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Ordre</label>
          <input type="number" name="order" value={String(fields.length)} min="0"
            style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
        </div>
      </div>

      <div style="display:grid; grid-template-columns:2fr 1fr; gap:12px; margin-bottom:12px">
        <div>
          <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Placeholder</label>
          <input type="text" name="placeholder" placeholder="Optionnel"
            style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
        </div>

        <div style="display:flex; align-items:center; gap:8px; padding-top:20px">
          <input type="checkbox" name="required" id="field-required" style="width:16px; height:16px; cursor:pointer" />
          <label for="field-required" style="font-size:14px; color:#374151; cursor:pointer">Champ obligatoire</label>
        </div>
      </div>

      <!-- Options (for select / radio / checkbox) -->
      <div id="options-block" style="margin-bottom:12px">
        <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">
          Options <span style="color:#9ca3af">(une par ligne — pour liste déroulante, choix unique, cases à cocher)</span>
        </label>
        <textarea name="options" rows="4" placeholder={"Option 1\nOption 2\nOption 3"}
          style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; font-family:monospace; resize:vertical"></textarea>
      </div>

      <div style="display:flex; justify-content:flex-end">
        <button type="submit"
          style="padding:8px 20px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:500; cursor:pointer">
          + Ajouter la question
        </button>
      </div>
    </form>
  </div>

  <!-- Fields list -->
  {fields.length === 0 ? (
    <div style="text-align:center; padding:60px; color:#9ca3af">
      <p style="font-size:16px">Aucune question dans ce formulaire.</p>
      <p style="font-size:13px; margin-top:6px">Ajoutez votre première question ci-dessus.</p>
    </div>
  ) : (
    <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden">
      <div style="background:#f9fafb; border-bottom:1px solid #e5e7eb; padding:10px 16px">
        <p style="font-size:13px; font-weight:600; color:#374151">
          {fields.length} question{fields.length !== 1 ? 's' : ''}
        </p>
      </div>
      <table style="width:100%; border-collapse:collapse; font-size:14px">
        <thead>
          <tr style="border-bottom:1px solid #e5e7eb">
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280; width:32px">#</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Question</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Type</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Placeholder</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Options</th>
            <th style="padding:10px 16px; text-align:center; font-weight:500; color:#6b7280">Obligatoire</th>
            <th style="padding:10px 16px; text-align:right; font-weight:500; color:#6b7280">Actions</th>
          </tr>
        </thead>
        <tbody>
          {fields.map((field) => {
            let parsedOptions: string[] = []
            try { parsedOptions = field.options ? JSON.parse(field.options) : [] } catch {}
            return (
              <tr style="border-bottom:1px solid #f3f4f6">
                <td style="padding:10px 16px; color:#9ca3af; font-size:13px">{field.orderIndex}</td>
                <td style="padding:10px 16px; font-weight:500">{field.label}</td>
                <td style="padding:10px 16px">
                  <span style="display:inline-block; padding:2px 8px; border-radius:4px; font-size:12px; font-weight:500; background:#f0f4ff; color:#2563eb">
                    {typeLabels[field.type] ?? field.type}
                  </span>
                </td>
                <td style="padding:10px 16px; color:#9ca3af; font-size:13px; font-style:italic">
                  {field.placeholder ?? <span style="color:#d1d5db">—</span>}
                </td>
                <td style="padding:10px 16px; font-size:12px; color:#6b7280">
                  {parsedOptions.length > 0
                    ? parsedOptions.join(', ')
                    : <span style="color:#d1d5db">—</span>}
                </td>
                <td style="padding:10px 16px; text-align:center">
                  {field.required ? (
                    <span style="color:#2563eb; font-size:13px; font-weight:600">✓</span>
                  ) : (
                    <span style="color:#d1d5db">—</span>
                  )}
                </td>
                <td style="padding:10px 16px; text-align:right">
                  <form method="POST" style="display:inline" onsubmit="return confirm('Supprimer cette question ?')">
                    <input type="hidden" name="_action" value="deleteField" />
                    <input type="hidden" name="field_id" value={String(field.id)} />
                    <button type="submit"
                      style="background:none; border:none; color:#ef4444; font-size:13px; cursor:pointer">
                      Supprimer
                    </button>
                  </form>
                </td>
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>
  )}
</Layout>
