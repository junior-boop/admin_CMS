---
import Layout from '../../layout.astro'
import { createCachedSystemClient } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const kv = env['CACHE'] as KVNamespace
const system = createCachedSystemClient(db, kv)

const { id } = Astro.params as { id: string }
const menuId = parseInt(id, 10)

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'addItem') {
    const label = (form.get('label') as string).trim()
    const url = (form.get('url') as string).trim()
    const target = (form.get('target') as '_self' | '_blank') ?? '_self'
    const className = (form.get('class_name') as string | null)?.trim() || null
    const parentIdRaw = form.get('parent_id') as string
    const parentId = parentIdRaw ? parseInt(parentIdRaw, 10) : undefined
    const order = parseInt(form.get('order') as string || '0', 10)
    if (label && url) {
      await system.menu.addItem(menuId, { label, url, target, className, order, parentId })
    }
  }

  if (action === 'deleteItem') {
    const itemId = parseInt(form.get('item_id') as string, 10)
    await system.menu.deleteItem(itemId)
  }

  return Astro.redirect(`/admin/system/menu/${id}`)
}

const menuData = await db.prepare('SELECT * FROM cms_menus WHERE id = ?').bind(menuId).first<{ id: number; name: string; slug: string }>()
if (!menuData) return new Response('Menu not found', { status: 404 })

const items = await db
  .prepare('SELECT * FROM cms_menu_items WHERE menu_id = ? ORDER BY order_index')
  .bind(menuId).all<{ id: number; label: string; url: string; target: string; class_name: string | null; order_index: number; parent_id: number | null }>()
const menuItems = items.results
---

<Layout config={config} title={`Menu: ${menuData.name}`} activeSystem="menu">
  <div class="page-header">
    <a href="/admin/system/menu" class="back-link">← Menus</a>
    <div class="title-group">
      <h1>{menuData.name}</h1>
      <span class="slug">/{menuData.slug}</span>
    </div>
  </div>

  <div class="form-card">
    <p class="card-title">Ajouter un item</p>
    <form method="POST" class="add-form">
      <input type="hidden" name="_action" value="addItem" />

      <div class="form-row">
        <div class="form-group">
          <label>Label *</label>
          <input type="text" name="label" required placeholder="ex: Accueil" class="form-input" />
        </div>

        <div class="form-group">
          <label>URL *</label>
          <input type="text" name="url" required placeholder="ex: /about" class="form-input" />
        </div>

        <div class="form-group">
          <label>Ouverture</label>
          <select name="target" class="form-select">
            <option value="_self">Même onglet</option>
            <option value="_blank">Nouvel onglet</option>
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Parent</label>
          <select name="parent_id" class="form-select">
            <option value="">— Aucun —</option>
            {menuItems.map((item) => (
              <option value={String(item.id)}>{item.label}</option>
            ))}
          </select>
        </div>

        <div class="form-group">
          <label>Class CSS</label>
          <input type="text" name="class_name" placeholder="ex: btn-primary" class="form-input mono" />
        </div>

        <div class="form-group small">
          <label>Ordre</label>
          <input type="number" name="order" value="0" min="0" class="form-input" />
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">
          + Ajouter
        </button>
      </div>
    </form>
  </div>

  {menuItems.length === 0 ? (
    <div class="empty-state">
      <p>Aucun item dans ce menu.</p>
    </div>
  ) : (
    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>Label</th>
            <th>URL</th>
            <th>Class CSS</th>
            <th>Cible</th>
            <th>Ordre</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {menuItems.map((item) => {
            const parent = menuItems.find(i => i.id === item.parent_id)
            return (
              <tr>
                <td class="label-cell">
                  {item.parent_id && <span class="indent">└</span>}
                  {item.label}
                  {parent && <span class="parent-tag">({parent.label})</span>}
                </td>
                <td class="mono">{item.url}</td>
                <td class="mono muted">{item.class_name ?? '—'}</td>
                <td>{item.target === '_blank' ? '↗' : '↗'}</td>
                <td class="muted">{item.order_index}</td>
                <td class="actions">
                  <form method="POST" onsubmit="return confirm('Supprimer cet item ?')">
                    <input type="hidden" name="_action" value="deleteItem" />
                    <input type="hidden" name="item_id" value={String(item.id)} />
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                  </form>
                </td>
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>
  )}
</Layout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .back-link {
    color: var(--text-light);
    font-size: 14px;
    text-decoration: none;
  }
  .back-link:hover { color: var(--primary); }
  .title-group {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .title-group h1 {
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
  }
  .slug {
    font-size: 13px;
    color: var(--text-light);
    font-family: monospace;
    background: var(--surface-elevated);
    padding: 4px 8px;
    border-radius: 6px;
  }
  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    box-shadow: var(--shadow);
  }
  .card-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 20px;
  }
  .add-form { display: flex; flex-direction: column; gap: 16px; }
  .form-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 768px) { .form-row { grid-template-columns: 1fr; } }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-group.small { max-width: 100px; }
  .form-group label {
    font-size: 12px;
    color: var(--text-light);
  }
  .form-input, .form-select {
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    transition: all 0.2s;
  }
  .form-input:focus, .form-select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgb(99 102 241 / 0.15);
  }
  .mono { font-family: monospace; }
  .form-actions {
    display: flex;
    justify-content: flex-end;
    padding-top: 8px;
  }
  .table-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }
  th {
    padding: 14px 20px;
    text-align: left;
    font-weight: 500;
    color: var(--text-light);
    background: var(--surface-elevated);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  td {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
  }
  tr:last-child td { border-bottom: none; }
  tr:hover { background: var(--surface-elevated); }
  .label-cell { font-weight: 500; }
  .indent { color: var(--text-light); margin-right: 8px; }
  .parent-tag {
    font-size: 12px;
    color: var(--text-light);
    font-weight: 400;
    margin-left: 8px;
  }
  .muted { color: var(--text-light); }
  .actions { text-align: right; white-space: nowrap; }
  .empty-state {
    text-align: center;
    padding: 60px;
    color: var(--text-light);
    background: var(--surface);
    border-radius: 16px;
  }
  .btn-sm { padding: 6px 12px; font-size: 12px; }

  @media (max-width: 768px) {
    .table-card { overflow-x: auto; }
    table { min-width: 600px; }
  }
</style>
