---
import Layout from '../layout.astro'
import { createCachedSystemClient } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const kv = env['CACHE'] as KVNamespace
const system = createCachedSystemClient(db, kv)

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'create') {
    const name = (form.get('name') as string).trim()
    const slug = (form.get('slug') as string).trim()
    const description = (form.get('description') as string | null)?.trim() || undefined
    if (name && slug) {
      await system.forms.create({ name, slug, description })
    }
  }

  if (action === 'delete') {
    const id = parseInt(form.get('id') as string, 10)
    await system.forms.delete(id)
  }

  return Astro.redirect('/admin/system/forms')
}

const forms = await system.forms.list()

// Count fields per form
const fieldCounts: Record<number, number> = {}
for (const f of forms) {
  const fields = await system.forms.listFields(f.id)
  fieldCounts[f.id] = fields.length
}
---

<Layout config={config} title="Formulaires" activeSystem="forms">
  <div class="page-header">
    <h1>Formulaires</h1>
    <span class="badge">{forms.length} formulaire{forms.length !== 1 ? 's' : ''}</span>
  </div>

  <div class="header-row">
    <button class="btn btn-primary" onclick="document.getElementById('modal-new').showModal()">
      + Nouveau formulaire
    </button>
  </div>

  {forms.length === 0 ? (
    <div class="empty-state">
      <p>Aucun formulaire pour l'instant.</p>
    </div>
  ) : (
    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>Nom</th>
            <th>Slug</th>
            <th>Description</th>
            <th>Questions</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {forms.map((f) => (
            <tr>
              <td class="name"><a href={`/admin/system/forms/${f.id}`}>{f.name}</a></td>
              <td class="mono">{f.slug}</td>
              <td class="muted">{f.description ?? '—'}</td>
              <td><span class="badge-sm">{fieldCounts[f.id] ?? 0} question{(fieldCounts[f.id] ?? 0) !== 1 ? 's' : ''}</span></td>
              <td class="actions">
                <a href={`/admin/system/forms/${f.id}`} class="btn btn-secondary btn-sm">Modifier</a>
                <form method="POST" onsubmit="return confirm('Supprimer ce formulaire et toutes ses questions ?')">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={String(f.id)} />
                  <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <dialog id="modal-new" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Nouveau formulaire</h2>
        <button class="close-btn" onclick="document.getElementById('modal-new').close()">×</button>
      </div>
      <form method="POST">
        <input type="hidden" name="_action" value="create" />
        <div class="modal-body">
          <div class="form-group">
            <label>Nom *</label>
            <input type="text" name="name" required placeholder="ex: Contact" class="form-input" />
          </div>
          <div class="form-group">
            <label>Slug *</label>
            <input type="text" name="slug" required placeholder="ex: contact" class="form-input mono" />
          </div>
          <div class="form-group">
            <label>Description</label>
            <input type="text" name="description" placeholder="Optionnel" class="form-input" />
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="document.getElementById('modal-new').close()">Annuler</button>
          <button type="submit" class="btn btn-primary">Créer</button>
        </div>
      </form>
    </div>
  </dialog>
</Layout>

<style>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .page-header h1 { font-size: 24px; font-weight: 600; color: var(--text); }
  .badge { font-size: 13px; color: var(--text-light); background: var(--surface-elevated); padding: 6px 12px; border-radius: 20px; }
  .header-row { margin-bottom: 20px; display: flex; justify-content: flex-end; }
  .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th { padding: 14px 20px; text-align: left; font-weight: 500; color: var(--text-light); background: var(--surface-elevated); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
  td { padding: 14px 20px; border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:hover { background: var(--surface-elevated); }
  .name { font-weight: 500; }
  .name a { color: var(--primary); text-decoration: none; }
  .mono { font-family: monospace; color: var(--text-muted); }
  .muted { color: var(--text-light); }
  .badge-sm { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; background: var(--surface-elevated); color: var(--text-muted); }
  .actions { text-align: right; display: flex; gap: 8px; justify-content: flex-end; }
  .btn-sm { padding: 6px 12px; font-size: 12px; }
  .empty-state { text-align: center; padding: 60px; color: var(--text-light); background: var(--surface); border-radius: 16px; }

  .modal { border: none; border-radius: 20px; padding: 0; background: transparent; max-width: 480px; width: 90%; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); }
  .modal::backdrop { background: rgb(0 0 0 / 0.5); backdrop-filter: blur(4px); }
  .modal-content { background: var(--surface); border-radius: 20px; overflow: hidden; }
  .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid var(--border); }
  .modal-header h2 { font-size: 18px; font-weight: 600; color: var(--text); }
  .close-btn { background: none; border: none; font-size: 28px; color: var(--text-light); cursor: pointer; line-height: 1; padding: 0; }
  .close-btn:hover { color: var(--text); }
  .modal-body { padding: 24px; display: flex; flex-direction: column; gap: 16px; }
  .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label { font-size: 13px; font-weight: 500; color: var(--text); }
  .form-input { padding: 12px 14px; border: 1px solid var(--border); border-radius: 10px; font-size: 14px; transition: all 0.2s; }
  .form-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgb(99 102 241 / 0.15); }
</style>
