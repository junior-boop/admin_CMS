---
import Layout from '../layout.astro'
import { createSystemClient } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const system = createSystemClient(db)

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const action = form.get('_action') as string

  if (action === 'create') {
    const name = (form.get('name') as string).trim()
    const slug = (form.get('slug') as string).trim()
    const description = (form.get('description') as string | null)?.trim() || undefined
    if (name && slug) {
      await system.forms.create({ name, slug, description })
    }
  }

  if (action === 'delete') {
    const id = parseInt(form.get('id') as string, 10)
    await system.forms.delete(id)
  }

  return Astro.redirect('/admin/system/forms')
}

const forms = await system.forms.list()

// Count fields per form
const fieldCounts: Record<number, number> = {}
for (const f of forms) {
  const fields = await system.forms.listFields(f.id)
  fieldCounts[f.id] = fields.length
}
---

<Layout config={config} title="Formulaires" activeSystem="forms">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px">
    <h1 style="font-size:22px; font-weight:600">Formulaires</h1>
    <span style="font-size:13px; color:#9ca3af">{forms.length} formulaire{forms.length !== 1 ? 's' : ''}</span>
  </div>

  <!-- Create form -->
  <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:20px; margin-bottom:24px">
    <p style="font-size:13px; font-weight:500; color:#374151; margin-bottom:12px">Nouveau formulaire</p>
    <form method="POST" style="display:grid; grid-template-columns:1fr 1fr 2fr auto; gap:12px; align-items:end">
      <input type="hidden" name="_action" value="create" />

      <div>
        <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Nom *</label>
        <input type="text" name="name" required placeholder="ex: Contact"
          style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
      </div>

      <div>
        <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Slug *</label>
        <input type="text" name="slug" required placeholder="ex: contact"
          style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; font-family:monospace" />
      </div>

      <div>
        <label style="font-size:12px; color:#6b7280; display:block; margin-bottom:4px">Description</label>
        <input type="text" name="description" placeholder="Optionnel"
          style="width:100%; padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
      </div>

      <button type="submit"
        style="padding:8px 16px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:500; cursor:pointer; white-space:nowrap">
        + Créer
      </button>
    </form>
  </div>

  <!-- Forms list -->
  {forms.length === 0 ? (
    <div style="text-align:center; padding:60px; color:#9ca3af">
      <p style="font-size:16px">Aucun formulaire pour l'instant.</p>
    </div>
  ) : (
    <div style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden">
      <table style="width:100%; border-collapse:collapse; font-size:14px">
        <thead>
          <tr style="background:#f9fafb; border-bottom:1px solid #e5e7eb">
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Nom</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Slug</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Description</th>
            <th style="padding:10px 16px; text-align:left; font-weight:500; color:#6b7280">Questions</th>
            <th style="padding:10px 16px; text-align:right; font-weight:500; color:#6b7280">Actions</th>
          </tr>
        </thead>
        <tbody>
          {forms.map((f) => (
            <tr style="border-bottom:1px solid #f3f4f6">
              <td style="padding:10px 16px; font-weight:500">
                <a href={`/admin/system/forms/${f.id}`} style="color:#2563eb; text-decoration:none">{f.name}</a>
              </td>
              <td style="padding:10px 16px; font-family:monospace; font-size:13px; color:#6b7280">{f.slug}</td>
              <td style="padding:10px 16px; color:#9ca3af; font-size:13px">{f.description ?? '—'}</td>
              <td style="padding:10px 16px">
                <span style="display:inline-block; padding:2px 8px; border-radius:4px; font-size:12px; background:#f3f4f6; color:#374151">
                  {fieldCounts[f.id] ?? 0} question{(fieldCounts[f.id] ?? 0) !== 1 ? 's' : ''}
                </span>
              </td>
              <td style="padding:10px 16px; text-align:right; display:flex; gap:8px; justify-content:flex-end">
                <a href={`/admin/system/forms/${f.id}`}
                  style="padding:5px 12px; background:#f0f4ff; color:#2563eb; border-radius:5px; font-size:12px; font-weight:500; text-decoration:none">
                  Modifier
                </a>
                <form method="POST" style="display:inline" onsubmit="return confirm('Supprimer ce formulaire et toutes ses questions ?')">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={String(f.id)} />
                  <button type="submit"
                    style="background:none; border:none; color:#ef4444; font-size:13px; cursor:pointer">
                    Supprimer
                  </button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Layout>
