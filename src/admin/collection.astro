---
import Layout from "./layout.astro";
import { createCMSClient } from "@geniusofdigital/astro-cms";
import { createCachedSystemClient } from "@geniusofdigital/astro-cms/system";
import type {
  ContentType,
  ContentTypeField,
  Entry,
} from "@geniusofdigital/astro-cms/system";
import { env as _cfEnv } from "cloudflare:workers";

const config = (await import("virtual:astro-cms/config")).default;
const { collection } = Astro.params as { collection: string };

const env = _cfEnv as Record<string, unknown>;
const db = env["DB"] as D1Database;
const kv = env["CACHE"] as KVNamespace;
const system = createCachedSystemClient(db, kv);

const isStatic = Boolean(config.collections[collection]);
let dynamicType: ContentType | null = null;
let dynamicFields: ContentTypeField[] = [];
let dynamicEntries: Entry[] = [];

if (!isStatic) {
  dynamicType = await system.contentTypes.getBySlug(collection);
  if (!dynamicType)
    return new Response("Collection introuvable", { status: 404 });
  dynamicFields = await system.contentTypes.listFields(dynamicType.id);
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action") as string;

  if (action === "delete") {
    try {
      const id = parseInt(form.get("id") as string, 10);
      if (isStatic) {
        const cms = createCMSClient(config, { db });
        await cms[collection]!.delete(id);
      } else {
        await system.entries.delete(id);
      }
    } catch (e) {
      console.error("Delete failed:", e);
    }
    return Astro.redirect(`/admin/${collection}`);
  }
}

let staticEntries: Record<string, unknown>[] = [];
let staticFields: string[] = [];

if (isStatic) {
  const cms = createCMSClient(config, { db });
  staticEntries = (await cms[collection]!.find({ limit: 50 })) as any;
  staticFields = Object.keys(config.collections[collection]!.fields);
} else {
  dynamicEntries = await system.entries.list(dynamicType!.id, { limit: 50 });
}

const label = isStatic
  ? collection.charAt(0).toUpperCase() + collection.slice(1)
  : dynamicType!.name;
---

<Layout config={config} title={label} activeCollection={collection} db={db}>
  <div class="page-header">
    <div class="title-row">
      <h1>{label}</h1>
      {!isStatic && (
        <a href={`/admin/system/content-types/${dynamicType!.id}`} class="link-btn">Gérer les champs</a>
      )}
    </div>
    <button class="btn btn-primary" onclick="document.getElementById('modal-new').showModal()">
      + Nouvelle entrée
    </button>
  </div>

  {isStatic && staticEntries.length === 0 && (
    <div class="empty-state">
      <p>Aucune entrée.</p>
      <button class="link-btn" onclick="document.getElementById('modal-new').showModal()">Créer la première →</button>
    </div>
  )}

  {!isStatic && dynamicFields.length === 0 && (
    <div class="empty-state">
      <p>Ce type n'a pas encore de champs.</p>
      <a href={`/admin/system/content-types/${dynamicType!.id}`} class="link-btn">Définir les champs →</a>
    </div>
  )}

  {!isStatic && dynamicFields.length > 0 && dynamicEntries.length === 0 && (
    <div class="empty-state">
      <p>Aucune entrée.</p>
      <button class="link-btn" onclick="document.getElementById('modal-new').showModal()">Créer la première →</button>
    </div>
  )}

  {(isStatic && staticEntries.length > 0) || (!isStatic && dynamicEntries.length > 0) && (
    <div class="table-card">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            {isStatic ? staticFields.slice(0, 3).map((f) => (
              <th>{f.charAt(0).toUpperCase() + f.slice(1)}</th>
            )) : dynamicFields.slice(0, 3).map((f) => (
              <th>{f.label}</th>
            ))}
            {!isStatic && <th>Statut</th>}
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {isStatic && staticEntries.map((entry) => (
            <tr>
              <td class="muted">{String(entry["id"])}</td>
              {staticFields.slice(0, 3).map((f) => (
                <td class="truncate">{entry[f] != null ? String(entry[f]).slice(0, 60) : <span class="placeholder">—</span>}</td>
              ))}
              <td class="muted">{new Date(String(entry["createdAt"] ?? entry["created_at"])).toLocaleDateString("fr-FR")}</td>
              <td class="actions">
                <a href={`/admin/${collection}/${entry["id"]}`} class="link-text">Modifier</a>
                <form method="POST" onsubmit="return confirm('Supprimer cette entrée ?')">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={String(entry["id"])} />
                  <button type="submit" class="btn-link danger">Supprimer</button>
                </form>
              </td>
            </tr>
          ))}
          {!isStatic && dynamicEntries.map((entry) => {
            let data = {}
            try { data = JSON.parse(entry.data) } catch {}
            const isPublished = entry.status === "published"
            return (
              <tr>
                <td class="muted">{entry.id}</td>
                {dynamicFields.slice(0, 3).map((f) => (
                  <td class="truncate">{data[f.name] != null ? String(data[f.name]).slice(0, 60) : <span class="placeholder">—</span>}</td>
                ))}
                <td><span class={`badge ${isPublished ? 'success' : ''}`}>{isPublished ? 'Publié' : 'Brouillon'}</span></td>
                <td class="muted">{new Date(entry.created_at).toLocaleDateString("fr-FR")}</td>
                <td class="actions">
                  <a href={`/admin/${collection}/${entry.id}`} class="link-text">Modifier</a>
                  <form method="POST" onsubmit="return confirm('Supprimer cette entrée ?')">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={String(entry.id)} />
                    <button type="submit" class="btn-link danger">Supprimer</button>
                  </form>
                </td>
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>
  )}

  <dialog id="modal-new" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Nouvelle entrée</h2>
        <button class="close-btn" onclick="document.getElementById('modal-new').close()">×</button>
      </div>
      <div class="modal-body">
        <p style="color: var(--text-light); margin-bottom: 16px;">Vous allez être redirigé vers le formulaire de création.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="document.getElementById('modal-new').close()">Annuler</button>
        <a href={`/admin/${collection}/new`} class="btn btn-primary">Continuer</a>
      </div>
    </div>
  </dialog>
</Layout>

<style>
  .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .title-row { display: flex; align-items: center; gap: 12px; }
  .title-row h1 { font-size: 24px; font-weight: 600; color: var(--text); }
  .link-btn { font-size: 12px; color: var(--text-muted); padding: 4px 10px; border: 1px solid var(--border); border-radius: 6px; text-decoration: none; }
  .link-btn:hover { background: var(--surface-elevated); }
  .empty-state { text-align: center; padding: 60px; color: var(--text-light); background: var(--surface); border-radius: 16px; }
  .table-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; box-shadow: var(--shadow); }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th { padding: 14px 20px; text-align: left; font-weight: 500; color: var(--text-light); background: var(--surface-elevated); font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; }
  td { padding: 14px 20px; border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:hover { background: var(--surface-elevated); }
  .muted { color: var(--text-light); }
  .truncate { max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .placeholder { color: var(--border); }
  .actions { text-align: right; display: flex; gap: 12px; justify-content: flex-end; }
  .link-text { color: var(--primary); font-size: 13px; }
  .btn-link { background: none; border: none; color: var(--danger); font-size: 13px; cursor: pointer; }
  .badge { display: inline-block; padding: 4px 10px; border-radius: 6px; font-size: 12px; background: var(--surface-elevated); color: var(--text-muted); }
  .badge.success { background: #f0fdf4; color: var(--success); }

  .modal { border: none; border-radius: 20px; padding: 0; background: transparent; max-width: 400px; width: 90%; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); }
  .modal::backdrop { background: rgb(0 0 0 / 0.5); backdrop-filter: blur(4px); }
  .modal-content { background: var(--surface); border-radius: 20px; overflow: hidden; }
  .modal-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid var(--border); }
  .modal-header h2 { font-size: 18px; font-weight: 600; color: var(--text); }
  .close-btn { background: none; border: none; font-size: 28px; color: var(--text-light); cursor: pointer; line-height: 1; padding: 0; }
  .close-btn:hover { color: var(--text); }
  .modal-body { padding: 24px; }
  .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; }
</style>
