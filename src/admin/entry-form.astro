---
import Layout from './layout.astro'
import { createCMSClient } from '@geniusofdigital/astro-cms'
import { createCachedSystemClient } from '@geniusofdigital/astro-cms/system'
import type { ContentType, ContentTypeField } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const { collection, id } = Astro.params as { collection: string; id?: string }

const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const kv = env['CACHE'] as KVNamespace
const system = createCachedSystemClient(db, kv)

const isStatic = Boolean(config.collections[collection])
let dynamicType: ContentType | null = null
let dynamicFields: ContentTypeField[] = []

if (!isStatic) {
  dynamicType = await system.contentTypes.getBySlug(collection)
  if (!dynamicType) return new Response('Collection introuvable', { status: 404 })
  dynamicFields = await system.contentTypes.listFields(dynamicType.id)
}

const isEdit = Boolean(id && id !== 'new')
let staticEntry: Record<string, unknown> | null = null
let dynamicEntryData: Record<string, unknown> = {}
let dynamicEntryStatus: 'draft' | 'published' = 'draft'

if (isEdit && id) {
  if (isStatic) {
    const cms = createCMSClient(config, { db })
    staticEntry = await cms[collection]!.findOne(parseInt(id, 10)) as Record<string, unknown> | null
    if (!staticEntry) return new Response('Entrée introuvable', { status: 404 })
  } else {
    const entry = await system.entries.get(parseInt(id, 10))
    if (!entry) return new Response('Entrée introuvable', { status: 404 })
    try { dynamicEntryData = JSON.parse(entry.data) } catch {}
    dynamicEntryStatus = entry.status
  }
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()

  try {
    if (isStatic) {
      const cms = createCMSClient(config, { db })
      const collectionDef = config.collections[collection]!
      const data: Record<string, unknown> = {}
      for (const [fieldName, field] of Object.entries(collectionDef.fields)) {
        const raw = form.get(fieldName)
        if (field.type === 'boolean') {
          data[fieldName] = raw === 'on'
        } else if (field.type === 'number') {
          data[fieldName] = raw ? parseFloat(raw as string) : null
        } else {
          data[fieldName] = raw ?? null
        }
      }
      if (isEdit && id) {
        await cms[collection]!.update(parseInt(id, 10), data as any)
      } else {
        await cms[collection]!.create(data as any)
      }
    } else {
      const data: Record<string, unknown> = {}
      for (const field of dynamicFields) {
        const raw = form.get(field.name)
        if (field.type === 'boolean') {
          data[field.name] = raw === 'on'
        } else if (field.type === 'number') {
          data[field.name] = raw ? parseFloat(raw as string) : null
        } else {
          data[field.name] = raw ?? null
        }
      }
      const status = (form.get('_status') as 'draft' | 'published') ?? 'draft'
      if (isEdit && id) {
        await system.entries.update(parseInt(id, 10), data, status)
      } else {
        await system.entries.create(dynamicType!.id, data, status)
      }
    }
  } catch (e) {
    console.error('Save entry failed:', e)
    return new Response('Erreur lors de la sauvegarde', { status: 500 })
  }

  return Astro.redirect(`/admin/${collection}`)
}

const label = isStatic
  ? collection.charAt(0).toUpperCase() + collection.slice(1)
  : dynamicType!.name
const pageTitle = isEdit ? `Modifier — ${label}` : `Nouvelle entrée — ${label}`
---

<Layout config={config} title={pageTitle} activeCollection={collection} db={db}>
  <div class="form-container">
    <div class="form-header">
      <a href={`/admin/${collection}`} class="back-link">← {label}</a>
      <h1>{pageTitle}</h1>
    </div>

    <form method="POST" id="entry-form" class="form-card">

      {/* ── Static collection fields ── */}
      {isStatic && (
        <div class="fields-grid">
          {Object.entries(config.collections[collection]!.fields).map(([fieldName, field]) => {
            const value = staticEntry ? String(staticEntry[fieldName] ?? '') : ''
            const labelText = (field.label ?? fieldName).charAt(0).toUpperCase() + (field.label ?? fieldName).slice(1)
            const required = field.required
            return (
              <div class="form-group" class:list={[{ 'full-width': field.type === 'richtext' }]}>
                <label for={fieldName} class="form-label">
                  {labelText}{required && <span class="required"> *</span>}
                </label>
                {field.type === 'richtext' ? (
                  <div>
                    <input type="hidden" name={fieldName} id={fieldName} value={value} />
                    <div class="tiptap-wrap" data-name={fieldName} data-initial={value}></div>
                  </div>
                ) : field.type === 'boolean' ? (
                  <div class="checkbox-group">
                    <input type="checkbox" id={fieldName} name={fieldName} checked={value === 'true'} class="checkbox" />
                    <label for={fieldName} class="checkbox-label">{labelText}</label>
                  </div>
                ) : field.type === 'select' ? (
                  <select id={fieldName} name={fieldName} required={required} class="form-select">
                    <option value="">— Choisir —</option>
                    {field.options.map((opt: string) => <option value={opt} selected={value === opt}>{opt}</option>)}
                  </select>
                ) : field.type === 'number' ? (
                  <input type="number" id={fieldName} name={fieldName} value={value} required={required} class="form-input" />
                ) : field.type === 'date' ? (
                  <input type="date" id={fieldName} name={fieldName} value={value} required={required} class="form-input" />
                ) : (
                  <input type="text" id={fieldName} name={fieldName} value={value} required={required} class="form-input" />
                )}
              </div>
            )
          })}
        </div>
      )}

      {/* ── Dynamic collection fields ── */}
      {!isStatic && dynamicFields.length === 0 && (
        <div class="empty-state">
          <p>Ce type n'a pas encore de champs.</p>
          <a href={`/admin/system/content-types/${dynamicType!.id}`} class="link">Définir les champs →</a>
        </div>
      )}

      {!isStatic && dynamicFields.length > 0 && (
        <div class="fields-grid">
          {dynamicFields.map((field) => {
            const value = String(dynamicEntryData[field.name] ?? '')
            const required = Boolean(field.required)
            const ph = field.placeholder ?? undefined
            let parsedOptions: string[] = []
            try { parsedOptions = field.options ? JSON.parse(field.options) : [] } catch {}
            const isWide = field.type === 'richtext' || field.type === 'textarea'
            return (
              <div class="form-group" class:list={[{ 'full-width': isWide }]}>
                <label for={`f_${field.id}`} class="form-label">
                  {field.label}{required && <span class="required"> *</span>}
                  <span class="field-name">{field.name}</span>
                </label>

                {field.type === 'richtext' ? (
                  <div>
                    <input type="hidden" name={field.name} id={`f_${field.id}`} value={value} />
                    <div class="tiptap-wrap" data-name={field.name} data-initial={value}></div>
                  </div>
                ) : field.type === 'textarea' ? (
                  <textarea id={`f_${field.id}`} name={field.name}
                    rows={4}
                    required={required}
                    placeholder={ph}
                    class="form-textarea">
                    {value}
                  </textarea>
                ) : field.type === 'boolean' ? (
                  <div class="checkbox-group">
                    <input type="checkbox" id={`f_${field.id}`} name={field.name}
                      checked={value === 'true'} class="checkbox" />
                    <label for={`f_${field.id}`} class="checkbox-label">{field.label}</label>
                  </div>
                ) : field.type === 'select' ? (
                  <select id={`f_${field.id}`} name={field.name} required={required} class="form-select">
                    <option value="">{ph ?? '— Choisir —'}</option>
                    {parsedOptions.map((opt) => <option value={opt} selected={value === opt}>{opt}</option>)}
                  </select>
                ) : field.type === 'number' ? (
                  <input type="number" id={`f_${field.id}`} name={field.name}
                    value={value} required={required} placeholder={ph} class="form-input" />
                ) : field.type === 'date' ? (
                  <input type="date" id={`f_${field.id}`} name={field.name}
                    value={value} required={required} class="form-input" />
                ) : field.type === 'email' ? (
                  <input type="email" id={`f_${field.id}`} name={field.name}
                    value={value} required={required} placeholder={ph ?? 'exemple@domaine.com'} class="form-input" />
                ) : field.type === 'url' ? (
                  <input type="url" id={`f_${field.id}`} name={field.name}
                    value={value} required={required} placeholder={ph ?? 'https://'} class="form-input" />
                ) : (
                  <input type="text" id={`f_${field.id}`} name={field.name}
                    value={value} required={required} placeholder={ph} class="form-input" />
                )}

                {field.help_text && (
                  <p class="help-text">{field.help_text}</p>
                )}
              </div>
            )
          })}
        </div>
      )}

      {/* ── Status (dynamic only) ── */}
      {!isStatic && dynamicFields.length > 0 && (
        <div class="form-section">
          <label class="form-label">Statut</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="_status" value="draft" checked={dynamicEntryStatus === 'draft'} class="radio" />
              <span class="radio-custom"></span>
              Brouillon
            </label>
            <label class="radio-label">
              <input type="radio" name="_status" value="published" checked={dynamicEntryStatus === 'published'} class="radio" />
              <span class="radio-custom"></span>
              Publié
            </label>
          </div>
        </div>
      )}

      <div class="form-actions">
        <a href={`/admin/${collection}`} class="btn btn-secondary">
          Annuler
        </a>
        <button type="submit" class="btn btn-primary">
          {isEdit ? 'Enregistrer' : 'Créer'}
        </button>
      </div>

    </form>
  </div>
</Layout>

<style>
  .form-container {
    max-width: 720px;
    margin: 0 auto;
  }
  .form-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }
  .back-link {
    color: var(--text-light);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--primary);
  }
  .form-header h1 {
    font-size: 24px;
    font-weight: 600;
    color: var(--text);
  }
  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    box-shadow: var(--shadow-lg);
  }
  .fields-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .fields-grid .full-width {
    grid-column: 1 / -1;
  }
  @media (max-width: 600px) {
    .fields-grid { grid-template-columns: 1fr; }
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .required { color: var(--danger); }
  .field-name {
    font-size: 11px;
    color: var(--text-light);
    font-weight: 400;
    font-family: monospace;
    background: var(--surface-elevated);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .form-input, .form-select, .form-textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 14px;
    color: var(--text);
    background: var(--surface);
    transition: all 0.2s ease;
  }
  .form-input:focus, .form-select:focus, .form-textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgb(99 102 241 / 0.15);
  }
  .form-textarea {
    resize: vertical;
    min-height: 120px;
    font-family: inherit;
  }
  .help-text {
    font-size: 12px;
    color: var(--text-light);
    margin-top: 4px;
  }
  .checkbox-group {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
  }
  .checkbox {
    width: 20px;
    height: 20px;
    accent-color: var(--primary);
    cursor: pointer;
  }
  .checkbox-label {
    font-size: 14px;
    color: var(--text-muted);
    cursor: pointer;
  }
  .form-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .radio-group {
    display: flex;
    gap: 24px;
  }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-muted);
    cursor: pointer;
  }
  .radio {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
  }
  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .empty-state {
    text-align: center;
    padding: 40px;
    color: var(--text-light);
  }
  .link {
    color: var(--primary);
    font-size: 14px;
    text-decoration: none;
  }
  .link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .form-card { padding: 20px; }
    .form-header { flex-direction: column; align-items: flex-start; gap: 8px; }
    .radio-group { flex-direction: column; gap: 12px; }
  }

  .tiptap-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 6px 8px;
    background: #f9fafb;
    border: 1px solid #d1d5db;
    border-bottom: none;
    border-radius: 6px 6px 0 0;
  }
  .tiptap-toolbar button {
    background: none;
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 13px;
    cursor: pointer;
    color: #374151;
    font-weight: 500;
    line-height: 1;
    transition: background 0.1s;
  }
  .tiptap-toolbar button:hover { background: #e5e7eb; }
  .tiptap-toolbar button.is-active { background: #dbeafe; color: #1d4ed8; }
  .tiptap-toolbar .sep {
    width: 1px;
    background: #e5e7eb;
    margin: 2px 4px;
  }
  .tiptap-content {
    border: 1px solid #d1d5db;
    border-radius: 0 0 6px 6px;
    padding: 12px;
    min-height: 200px;
    font-size: 14px;
    line-height: 1.7;
    outline: none;
    cursor: text;
  }
  .tiptap-content:focus-within { border-color: #2563eb; box-shadow: 0 0 0 2px #dbeafe; }
  .tiptap-content p { margin: 0 0 8px; }
  .tiptap-content p:last-child { margin-bottom: 0; }
  .tiptap-content h1 { font-size: 22px; font-weight: 700; margin: 16px 0 8px; }
  .tiptap-content h2 { font-size: 18px; font-weight: 600; margin: 14px 0 6px; }
  .tiptap-content h3 { font-size: 16px; font-weight: 600; margin: 12px 0 4px; }
  .tiptap-content strong { font-weight: 600; }
  .tiptap-content em { font-style: italic; }
  .tiptap-content ul, .tiptap-content ol { padding-left: 20px; margin: 8px 0; }
  .tiptap-content li { margin: 2px 0; }
  .tiptap-content blockquote {
    border-left: 3px solid #d1d5db;
    padding-left: 12px;
    color: #6b7280;
    margin: 8px 0;
  }
  .tiptap-content code {
    background: #f3f4f6;
    padding: 1px 4px;
    border-radius: 3px;
    font-family: monospace;
    font-size: 13px;
  }
  .tiptap-content pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 12px;
    border-radius: 6px;
    overflow-x: auto;
    font-family: monospace;
    font-size: 13px;
    margin: 8px 0;
  }
  .tiptap-content .ProseMirror { outline: none; min-height: 160px; }
  .tiptap-content .ProseMirror p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    color: #9ca3af;
    pointer-events: none;
    float: left;
    height: 0;
  }
</style>

<script>
  import { Editor } from '@tiptap/core'
  import StarterKit from '@tiptap/starter-kit'
  import Placeholder from '@tiptap/extension-placeholder'

  function initEditors() {
    document.querySelectorAll<HTMLElement>('.tiptap-wrap').forEach((wrap) => {
      if (wrap.dataset.initialized) return
      wrap.dataset.initialized = 'true'

      const fieldName = wrap.dataset.name!
      const initial = wrap.dataset.initial ?? ''
      const hidden = document.querySelector<HTMLInputElement>(`input[type="hidden"][name="${fieldName}"]`)
      if (!hidden) return

      const toolbar = document.createElement('div')
      toolbar.className = 'tiptap-toolbar'
      toolbar.innerHTML = `
        <button type="button" data-cmd="bold" title="Gras"><b>B</b></button>
        <button type="button" data-cmd="italic" title="Italique"><i>I</i></button>
        <button type="button" data-cmd="strike" title="Barré"><s>S</s></button>
        <div class="sep"></div>
        <button type="button" data-cmd="h1" title="Titre 1">H1</button>
        <button type="button" data-cmd="h2" title="Titre 2">H2</button>
        <button type="button" data-cmd="h3" title="Titre 3">H3</button>
        <div class="sep"></div>
        <button type="button" data-cmd="bulletList" title="Liste à puces">• —</button>
        <button type="button" data-cmd="orderedList" title="Liste numérotée">1.</button>
        <button type="button" data-cmd="blockquote" title="Citation">❝</button>
        <button type="button" data-cmd="codeBlock" title="Bloc de code">&lt;/&gt;</button>
        <div class="sep"></div>
        <button type="button" data-cmd="undo" title="Annuler">↩</button>
        <button type="button" data-cmd="redo" title="Rétablir">↪</button>
      `

      const editorEl = document.createElement('div')
      editorEl.className = 'tiptap-content'

      wrap.appendChild(toolbar)
      wrap.appendChild(editorEl)

      const editor = new Editor({
        element: editorEl,
        extensions: [
          StarterKit,
          Placeholder.configure({ placeholder: 'Commencez à écrire...' }),
        ],
        content: initial,
        onUpdate({ editor }) {
          hidden.value = editor.getHTML()
        },
      })

      hidden.value = editor.getHTML()

      toolbar.querySelectorAll<HTMLButtonElement>('[data-cmd]').forEach((btn) => {
        btn.addEventListener('mousedown', (e) => {
          e.preventDefault()
          const cmd = btn.dataset.cmd!
          const chain = editor.chain().focus()
          if (cmd === 'bold') chain.toggleBold().run()
          else if (cmd === 'italic') chain.toggleItalic().run()
          else if (cmd === 'strike') chain.toggleStrike().run()
          else if (cmd === 'h1') chain.toggleHeading({ level: 1 }).run()
          else if (cmd === 'h2') chain.toggleHeading({ level: 2 }).run()
          else if (cmd === 'h3') chain.toggleHeading({ level: 3 }).run()
          else if (cmd === 'bulletList') chain.toggleBulletList().run()
          else if (cmd === 'orderedList') chain.toggleOrderedList().run()
          else if (cmd === 'blockquote') chain.toggleBlockquote().run()
          else if (cmd === 'codeBlock') chain.toggleCodeBlock().run()
          else if (cmd === 'undo') chain.undo().run()
          else if (cmd === 'redo') chain.redo().run()
          updateToolbar()
        })
      })

      function updateToolbar() {
        toolbar.querySelectorAll<HTMLButtonElement>('[data-cmd]').forEach((btn) => {
          const cmd = btn.dataset.cmd!
          let active = false
          if (cmd === 'bold') active = editor.isActive('bold')
          else if (cmd === 'italic') active = editor.isActive('italic')
          else if (cmd === 'strike') active = editor.isActive('strike')
          else if (cmd === 'h1') active = editor.isActive('heading', { level: 1 })
          else if (cmd === 'h2') active = editor.isActive('heading', { level: 2 })
          else if (cmd === 'h3') active = editor.isActive('heading', { level: 3 })
          else if (cmd === 'bulletList') active = editor.isActive('bulletList')
          else if (cmd === 'orderedList') active = editor.isActive('orderedList')
          else if (cmd === 'blockquote') active = editor.isActive('blockquote')
          else if (cmd === 'codeBlock') active = editor.isActive('codeBlock')
          btn.classList.toggle('is-active', active)
        })
      }

      editor.on('selectionUpdate', updateToolbar)
      editor.on('transaction', updateToolbar)
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEditors)
  } else {
    initEditors()
  }
</script>
