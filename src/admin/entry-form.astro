---
import Layout from './layout.astro'
import { createCMSClient } from '@geniusofdigital/astro-cms'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const { collection, id } = Astro.params as { collection: string; id?: string }

if (!config.collections[collection]) {
  return new Response('Not found', { status: 404 })
}

const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const cms = createCMSClient(config, { db })

const isEdit = Boolean(id && id !== 'new')
let entry: Record<string, unknown> | null = null

if (isEdit && id) {
  entry = await cms[collection]!.findOne(parseInt(id, 10)) as Record<string, unknown> | null
  if (!entry) return new Response('Entry not found', { status: 404 })
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const collectionDef = config.collections[collection]!
  const data: Record<string, unknown> = {}

  for (const [fieldName, field] of Object.entries(collectionDef.fields)) {
    const raw = form.get(fieldName)
    if (field.type === 'boolean') {
      data[fieldName] = raw === 'on'
    } else if (field.type === 'number') {
      data[fieldName] = raw ? parseFloat(raw as string) : null
    } else {
      data[fieldName] = raw ?? null
    }
  }

  if (isEdit && id) {
    await cms[collection]!.update(parseInt(id, 10), data as any)
  } else {
    await cms[collection]!.create(data as any)
  }
  return Astro.redirect(`/admin/${collection}`)
}

const collectionDef = config.collections[collection]!
const label = collection.charAt(0).toUpperCase() + collection.slice(1)
const pageTitle = isEdit ? `Edit ${label}` : `New ${label}`
---

<Layout config={config} title={pageTitle} activeCollection={collection}>
  <div style="max-width:680px">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px">
      <a href={`/admin/${collection}`} style="color:#6b7280; font-size:13px; text-decoration:none">← Back</a>
      <h1 style="font-size:20px; font-weight:600">{pageTitle}</h1>
    </div>

    <form method="POST" style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:24px; display:flex; flex-direction:column; gap:20px">

      {Object.entries(collectionDef.fields).map(([fieldName, field]) => {
        const value = entry ? String(entry[fieldName] ?? '') : ''
        const labelText = (field.label ?? fieldName).charAt(0).toUpperCase() + (field.label ?? fieldName).slice(1)
        const required = field.required

        return (
          <div style="display:flex; flex-direction:column; gap:6px">
            <label for={fieldName} style="font-size:13px; font-weight:500; color:#374151">
              {labelText}{required && <span style="color:#ef4444"> *</span>}
            </label>

            {field.type === 'richtext' ? (
              <textarea id={fieldName} name={fieldName} rows={8} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; resize:vertical; font-family:inherit">
                {value}
              </textarea>
            ) : field.type === 'boolean' ? (
              <input type="checkbox" id={fieldName} name={fieldName}
                checked={value === 'true'} style="width:16px; height:16px" />
            ) : field.type === 'select' ? (
              <select id={fieldName} name={fieldName} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; background:#fff">
                <option value="">— Select —</option>
                {field.options.map((opt: string) => (
                  <option value={opt} selected={value === opt}>{opt}</option>
                ))}
              </select>
            ) : field.type === 'number' ? (
              <input type="number" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            ) : field.type === 'date' ? (
              <input type="date" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            ) : (
              <input type="text" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            )}
          </div>
        )
      })}

      <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:8px; border-top:1px solid #f3f4f6">
        <a href={`/admin/${collection}`}
           style="padding:8px 16px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; color:#374151; text-decoration:none">
          Cancel
        </a>
        <button type="submit"
          style="padding:8px 20px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:500; cursor:pointer">
          {isEdit ? 'Save changes' : 'Create'}
        </button>
      </div>

    </form>
  </div>
</Layout>
