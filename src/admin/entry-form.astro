---
import Layout from './layout.astro'
import { createCMSClient } from '@geniusofdigital/astro-cms'
import { createSystemClient } from '@geniusofdigital/astro-cms/system'
import type { ContentType, ContentTypeField } from '@geniusofdigital/astro-cms/system'
import { env as _cfEnv } from 'cloudflare:workers'

const config = (await import('virtual:astro-cms/config')).default
const { collection, id } = Astro.params as { collection: string; id?: string }

const env = _cfEnv as Record<string, unknown>
const db = env['DB'] as D1Database
const system = createSystemClient(db)

const isStatic = Boolean(config.collections[collection])
let dynamicType: ContentType | null = null
let dynamicFields: ContentTypeField[] = []

if (!isStatic) {
  dynamicType = await system.contentTypes.getBySlug(collection)
  if (!dynamicType) return new Response('Collection introuvable', { status: 404 })
  dynamicFields = await system.contentTypes.listFields(dynamicType.id)
}

const isEdit = Boolean(id && id !== 'new')
let staticEntry: Record<string, unknown> | null = null
let dynamicEntryData: Record<string, unknown> = {}
let dynamicEntryStatus: 'draft' | 'published' = 'draft'

if (isEdit && id) {
  if (isStatic) {
    const cms = createCMSClient(config, { db })
    staticEntry = await cms[collection]!.findOne(parseInt(id, 10)) as Record<string, unknown> | null
    if (!staticEntry) return new Response('Entrée introuvable', { status: 404 })
  } else {
    const entry = await system.entries.get(parseInt(id, 10))
    if (!entry) return new Response('Entrée introuvable', { status: 404 })
    try { dynamicEntryData = JSON.parse(entry.data) } catch {}
    dynamicEntryStatus = entry.status
  }
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()

  if (isStatic) {
    const cms = createCMSClient(config, { db })
    const collectionDef = config.collections[collection]!
    const data: Record<string, unknown> = {}
    for (const [fieldName, field] of Object.entries(collectionDef.fields)) {
      const raw = form.get(fieldName)
      if (field.type === 'boolean') {
        data[fieldName] = raw === 'on'
      } else if (field.type === 'number') {
        data[fieldName] = raw ? parseFloat(raw as string) : null
      } else {
        data[fieldName] = raw ?? null
      }
    }
    if (isEdit && id) {
      await cms[collection]!.update(parseInt(id, 10), data as any)
    } else {
      await cms[collection]!.create(data as any)
    }
  } else {
    const data: Record<string, unknown> = {}
    for (const field of dynamicFields) {
      const raw = form.get(field.name)
      if (field.type === 'boolean') {
        data[field.name] = raw === 'on'
      } else if (field.type === 'number') {
        data[field.name] = raw ? parseFloat(raw as string) : null
      } else {
        data[field.name] = raw ?? null
      }
    }
    const status = (form.get('_status') as 'draft' | 'published') ?? 'draft'
    if (isEdit && id) {
      await system.entries.update(parseInt(id, 10), data, status)
    } else {
      await system.entries.create(dynamicType!.id, data, status)
    }
  }

  return Astro.redirect(`/admin/${collection}`)
}

const label = isStatic
  ? collection.charAt(0).toUpperCase() + collection.slice(1)
  : dynamicType!.name
const pageTitle = isEdit ? `Modifier — ${label}` : `Nouvelle entrée — ${label}`
---

<Layout config={config} title={pageTitle} activeCollection={collection} db={db}>
  <div style="max-width:720px">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:28px">
      <a href={`/admin/${collection}`} style="color:#6b7280; font-size:13px; text-decoration:none">← {label}</a>
      <h1 style="font-size:20px; font-weight:600">{pageTitle}</h1>
    </div>

    <form method="POST" style="background:#fff; border:1px solid #e5e7eb; border-radius:8px; padding:24px; display:flex; flex-direction:column; gap:20px">

      {/* ── Static collection fields ── */}
      {isStatic && Object.entries(config.collections[collection]!.fields).map(([fieldName, field]) => {
        const value = staticEntry ? String(staticEntry[fieldName] ?? '') : ''
        const labelText = (field.label ?? fieldName).charAt(0).toUpperCase() + (field.label ?? fieldName).slice(1)
        const required = field.required
        return (
          <div style="display:flex; flex-direction:column; gap:6px">
            <label for={fieldName} style="font-size:13px; font-weight:500; color:#374151">
              {labelText}{required && <span style="color:#ef4444"> *</span>}
            </label>
            {field.type === 'richtext' ? (
              <textarea id={fieldName} name={fieldName} rows={8} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; resize:vertical; font-family:inherit">
                {value}
              </textarea>
            ) : field.type === 'boolean' ? (
              <input type="checkbox" id={fieldName} name={fieldName} checked={value === 'true'} style="width:16px; height:16px" />
            ) : field.type === 'select' ? (
              <select id={fieldName} name={fieldName} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; background:#fff">
                <option value="">— Choisir —</option>
                {field.options.map((opt: string) => <option value={opt} selected={value === opt}>{opt}</option>)}
              </select>
            ) : field.type === 'number' ? (
              <input type="number" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            ) : field.type === 'date' ? (
              <input type="date" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            ) : (
              <input type="text" id={fieldName} name={fieldName} value={value} required={required}
                style="padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px" />
            )}
          </div>
        )
      })}

      {/* ── Dynamic collection fields ── */}
      {!isStatic && dynamicFields.length === 0 && (
        <div style="text-align:center; padding:40px; color:#9ca3af">
          <p>Ce type n'a pas encore de champs.</p>
          <a href={`/admin/system/content-types/${dynamicType!.id}`} style="color:#2563eb; font-size:14px">Définir les champs →</a>
        </div>
      )}

      {!isStatic && dynamicFields.map((field) => {
        const value = String(dynamicEntryData[field.name] ?? '')
        const required = Boolean(field.required)
        const ph = field.placeholder ?? undefined
        let parsedOptions: string[] = []
        try { parsedOptions = field.options ? JSON.parse(field.options) : [] } catch {}
        const inputStyle = "padding:8px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; width:100%"
        return (
          <div style="display:flex; flex-direction:column; gap:4px">
            <label for={`f_${field.id}`} style="font-size:13px; font-weight:500; color:#374151">
              {field.label}{required && <span style="color:#ef4444"> *</span>}
              <span style="font-size:11px; color:#9ca3af; font-weight:400; margin-left:6px; font-family:monospace">{field.name}</span>
            </label>

            {field.type === 'richtext' || field.type === 'textarea' ? (
              <textarea id={`f_${field.id}`} name={field.name}
                rows={field.type === 'richtext' ? 8 : 4}
                required={required}
                placeholder={ph}
                style={`${inputStyle}; resize:vertical; font-family:inherit`}>
                {value}
              </textarea>
            ) : field.type === 'boolean' ? (
              <div style="display:flex; align-items:center; gap:8px; padding:6px 0">
                <input type="checkbox" id={`f_${field.id}`} name={field.name}
                  checked={value === 'true'} style="width:16px; height:16px; cursor:pointer" />
                <label for={`f_${field.id}`} style="font-size:14px; color:#374151; cursor:pointer">{field.label}</label>
              </div>
            ) : field.type === 'select' ? (
              <select id={`f_${field.id}`} name={field.name} required={required}
                style={`${inputStyle}; background:#fff`}>
                <option value="">{ph ?? '— Choisir —'}</option>
                {parsedOptions.map((opt) => <option value={opt} selected={value === opt}>{opt}</option>)}
              </select>
            ) : field.type === 'number' ? (
              <input type="number" id={`f_${field.id}`} name={field.name}
                value={value} required={required} placeholder={ph} style={inputStyle} />
            ) : field.type === 'date' ? (
              <input type="date" id={`f_${field.id}`} name={field.name}
                value={value} required={required} style={inputStyle} />
            ) : field.type === 'email' ? (
              <input type="email" id={`f_${field.id}`} name={field.name}
                value={value} required={required} placeholder={ph ?? 'exemple@domaine.com'} style={inputStyle} />
            ) : field.type === 'url' ? (
              <input type="url" id={`f_${field.id}`} name={field.name}
                value={value} required={required} placeholder={ph ?? 'https://'} style={inputStyle} />
            ) : (
              <input type="text" id={`f_${field.id}`} name={field.name}
                value={value} required={required} placeholder={ph} style={inputStyle} />
            )}

            {field.helpText && (
              <p style="font-size:12px; color:#6b7280; margin-top:2px">{field.helpText}</p>
            )}
          </div>
        )
      })}

      {/* ── Status (dynamic only) ── */}
      {!isStatic && dynamicFields.length > 0 && (
        <div style="display:flex; flex-direction:column; gap:6px; padding-top:4px; border-top:1px solid #f3f4f6">
          <label style="font-size:13px; font-weight:500; color:#374151">Statut</label>
          <div style="display:flex; gap:16px">
            <label style="display:flex; align-items:center; gap:6px; font-size:14px; cursor:pointer">
              <input type="radio" name="_status" value="draft" checked={dynamicEntryStatus === 'draft'} />
              Brouillon
            </label>
            <label style="display:flex; align-items:center; gap:6px; font-size:14px; cursor:pointer">
              <input type="radio" name="_status" value="published" checked={dynamicEntryStatus === 'published'} />
              Publié
            </label>
          </div>
        </div>
      )}

      <div style="display:flex; justify-content:flex-end; gap:10px; padding-top:8px; border-top:1px solid #f3f4f6">
        <a href={`/admin/${collection}`}
           style="padding:8px 16px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; color:#374151; text-decoration:none">
          Annuler
        </a>
        <button type="submit"
          style="padding:8px 20px; background:#2563eb; color:#fff; border:none; border-radius:6px; font-size:14px; font-weight:500; cursor:pointer">
          {isEdit ? 'Enregistrer' : 'Créer'}
        </button>
      </div>

    </form>
  </div>
</Layout>
