{
  "name": "@geniusofdigital/astro-cms",
  "version": "0.1.25",
  "description": "A type-safe CMS runtime for Astro + Cloudflare (D1, R2, KV)",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist",
    "bin",
    "src/admin"
  ],
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./astro": {
      "types": "./dist/astro/integration.d.ts",
      "import": "./dist/astro/integration.js"
    },
    "./middleware": {
      "types": "./dist/astro/middleware.d.ts",
      "import": "./dist/astro/middleware.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./system": {
      "types": "./dist/system/index.d.ts",
      "import": "./dist/system/index.js"
    }
  },
  "bin": {
    "astro-cms": "./bin/astro-cms.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.runtime.json && tsc -p tsconfig.cli.json && tsc -p tsconfig.astro.json",
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 tsc -p tsconfig.runtime.json --watch",
    "typecheck": "tsc -p tsconfig.runtime.json --noEmit && tsc -p tsconfig.cli.json --noEmit && tsc -p tsconfig.astro.json --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "jiti": "^2.6.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@types/node": "^25.6.0",
    "astro": "^4.14.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "astro": ">=4.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
